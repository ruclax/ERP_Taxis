{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "allowJs": false,
    "declaration": false,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@erp/shared/*": ["packages/shared/*"],
      "@erp/db/*": ["packages/db/*"],
      "@erp/auth/*": ["packages/auth/*"],
      "@erp/ui/*": ["packages/ui/*"]
    }
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules", "**/node_modules", "**/dist", "**/.next", "prototype"]
}
