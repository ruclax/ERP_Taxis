# ─────────────────────────────────────────────────────────────
# ERP Taxi — variables de entorno
# Copia este archivo a `.env.local` y reemplaza los valores.
# `.env.local` está en .gitignore — NUNCA se commitea.
# ─────────────────────────────────────────────────────────────

# ── Cliente público (web + móvil) ────────────────────────────
# Dashboard Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Dashboard Supabase → Project Settings → API → Project API Keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Servidor / scripts admin (NUNCA exponer al cliente) ──────
# Dashboard Supabase → Project Settings → API → Project API Keys → service_role (¡SECRETA!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── PostgreSQL directo (para migraciones y seed) ─────────────
# Dashboard Supabase → Project Settings → Database → Connection string → URI (modo "Session pooler")
# Reemplaza [YOUR-PASSWORD] con la contraseña que estableciste al crear el proyecto.
# Si la olvidaste: Dashboard → Database → Reset database password
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-us-west-1.pooler.supabase.com:5432/postgres

# ── Configuración opcional ───────────────────────────────────
# Nivel de log de los scripts (info | debug | silent)
LOG_LEVEL=info
